# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xoxoedu
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/xoxoedu

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with scripts/generate_rsa_keys.py
# Store the PEM with literal \n (not actual newlines)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth — 32-byte hex string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@xoxoedu.com

# App
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]
