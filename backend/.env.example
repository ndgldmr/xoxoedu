# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/xoxoedu
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/xoxoedu

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with scripts/generate_rsa_keys.py
# Store the PEM with literal \n (not actual newlines)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth — 32-byte hex string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@xoxoedu.com

# Object storage (S3-compatible — Cloudflare R2 in production, MinIO locally)
#
# Local dev (MinIO via Docker):
#   R2_ENDPOINT_URL=http://localhost:9000
#   R2_ACCESS_KEY_ID=minioadmin
#   R2_SECRET_ACCESS_KEY=minioadmin
#   R2_PUBLIC_URL=http://localhost:9000/xoxoedu-uploads
#
# Production (Cloudflare R2):
#   Leave R2_ENDPOINT_URL empty — endpoint is derived from R2_ACCOUNT_ID.
#   Create an API token at dash.cloudflare.com → R2 → Manage R2 API tokens.
R2_ENDPOINT_URL=
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=xoxoedu-uploads
# Optional: custom public domain bound to the bucket (e.g. assets.xoxoedu.com)
R2_PUBLIC_URL=

# Stripe
# Get keys from dashboard.stripe.com/test/apikeys
# Webhook secret: run `stripe listen --forward-to localhost:8000/api/v1/payments/webhook`
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# AI / LLM (Sprint 7)
# Get your API key from aistudio.google.com/apikey
# LiteLLM reads this automatically when using the gemini/ model prefix
GEMINI_API_KEY=your-gemini-api-key
# Model is swappable via this var — any litellm-supported identifier works
AI_MODEL=gemini/gemini-2.0-flash
# Default monthly token budget per user (overridden per-course via admin API)
AI_MONTHLY_TOKEN_BUDGET=100000

# Mux (video hosting — Sprint 8A)
# Get credentials from dashboard.mux.com → Settings → API Access Tokens
# Webhook secret: dashboard.mux.com → Settings → Webhooks → your endpoint
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# OpenAI (Whisper transcription — Sprint 8A)
# Get your API key from platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# App
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]
